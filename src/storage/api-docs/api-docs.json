{
    "openapi": "3.0.0",
    "info": {
        "title": "FLOZ Platform API",
        "description": "API documentation for FLOZ Platform and Tenant specific features",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api",
            "description": "Primary API Server"
        }
    ],
    "paths": {
        "/api/health": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "Health Check",
                "description": "Check if the API is running",
                "operationId": "1cdb246a0cc7a61b4444b09dfd4954bb",
                "responses": {
                    "200": {
                        "description": "API is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dan dapatkan Sanctum token",
                "operationId": "729051a72c82e45c2414c9e5b3450480",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil"
                    },
                    "401": {
                        "description": "Email atau password salah"
                    },
                    "403": {
                        "description": "Akun tidak aktif atau parent"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout (revoke current token)",
                "operationId": "fb4bf3a224c61f0b366538e251e934b9",
                "responses": {
                    "204": {
                        "description": "Logout berhasil"
                    },
                    "401": {
                        "description": "Token tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Profil user yang sedang login",
                "operationId": "a2bbab381ba3b6aa5b022472b3cbd925",
                "responses": {
                    "200": {
                        "description": "Profile data"
                    },
                    "401": {
                        "description": "Token tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "User Login",
                "description": "Authenticate user and return redirect",
                "operationId": "a0bad38435a32b5ad173da486ba8f59d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@sekolah.id"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret"
                                    },
                                    "remember": {
                                        "type": "boolean",
                                        "example": false
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "User Logout",
                "description": "Logout the authenticated user",
                "operationId": "fe1c1eca634ba2811908fec5e5183950",
                "responses": {
                    "302": {
                        "description": "Redirect to home"
                    }
                }
            }
        },
        "/tenant/dashboard": {
            "get": {
                "tags": [
                    "Tenant Dashboard"
                ],
                "summary": "Tenant Dashboard Stats",
                "description": "Get statistics for the tenant dashboard",
                "operationId": "a32eae9558575e32b720bac70aad28c3",
                "responses": {
                    "200": {
                        "description": "Dashboard stats",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "stats": {
                                            "properties": {
                                                "total_students": {
                                                    "type": "integer"
                                                },
                                                "total_teachers": {
                                                    "type": "integer"
                                                },
                                                "total_classes": {
                                                    "type": "integer"
                                                },
                                                "total_staff": {
                                                    "type": "integer"
                                                },
                                                "attendance_present": {
                                                    "type": "integer"
                                                },
                                                "attendance_absent": {
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "recent_announcements": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tenant/grades": {
            "get": {
                "tags": [
                    "Grades"
                ],
                "summary": "List Grades",
                "description": "Get list of grades with filtering",
                "operationId": "fac99c04296b004c30baad90529aac58",
                "parameters": [
                    {
                        "name": "class_id",
                        "in": "query",
                        "description": "Filter by class ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "semester_id",
                        "in": "query",
                        "description": "Filter by semester ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "subject_id",
                        "in": "query",
                        "description": "Filter by subject ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of grades"
                    }
                }
            }
        },
        "/tenant/grades/batch": {
            "get": {
                "tags": [
                    "Grades"
                ],
                "summary": "Batch Input View",
                "description": "Get view for batch grade input",
                "operationId": "72f2f64c7aff22482aec03961fe3825b",
                "parameters": [
                    {
                        "name": "class_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "semester_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "subject_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Batch input view"
                    }
                }
            },
            "post": {
                "tags": [
                    "Grades"
                ],
                "summary": "Store Batch Grades",
                "description": "Store multiple grades at once",
                "operationId": "1ed56bcad8dd0a8c30eb8ca00906f0e0",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "class_id",
                                    "semester_id",
                                    "subject_id",
                                    "grades"
                                ],
                                "properties": {
                                    "class_id": {
                                        "type": "integer"
                                    },
                                    "semester_id": {
                                        "type": "integer"
                                    },
                                    "subject_id": {
                                        "type": "integer"
                                    },
                                    "grades": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "student_id": {
                                                    "type": "integer"
                                                },
                                                "daily_test_avg": {
                                                    "type": "number"
                                                },
                                                "mid_test": {
                                                    "type": "number"
                                                },
                                                "final_test": {
                                                    "type": "number"
                                                },
                                                "knowledge_score": {
                                                    "type": "number"
                                                },
                                                "skill_score": {
                                                    "type": "number"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect to index"
                    }
                }
            }
        },
        "/tenant/report-cards": {
            "get": {
                "tags": [
                    "Report Cards"
                ],
                "summary": "List Report Cards",
                "description": "Get list of report cards with filtering",
                "operationId": "cb0c8bf4bd22e7d3548b7b7ce656c1de",
                "parameters": [
                    {
                        "name": "class_id",
                        "in": "query",
                        "description": "Filter by class ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "semester_id",
                        "in": "query",
                        "description": "Filter by semester ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by status",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "draft",
                                "published"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of report cards"
                    }
                }
            }
        },
        "/tenant/report-cards/generate": {
            "post": {
                "tags": [
                    "Report Cards"
                ],
                "summary": "Generate Report Cards",
                "description": "Generate report cards for a class and semester",
                "operationId": "217366120cd0d7b1378ed9449828a4bc",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "class_id",
                                    "semester_id",
                                    "report_type"
                                ],
                                "properties": {
                                    "class_id": {
                                        "type": "integer"
                                    },
                                    "semester_id": {
                                        "type": "integer"
                                    },
                                    "report_type": {
                                        "type": "string",
                                        "enum": [
                                            "uts",
                                            "final"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect to index"
                    }
                }
            }
        },
        "/tenant/report-cards/{reportCard}": {
            "get": {
                "tags": [
                    "Report Cards"
                ],
                "summary": "Show Report Card",
                "description": "Get detailed view of a report card",
                "operationId": "9d65f2d60ef8f851d1e908c57f2f20d8",
                "parameters": [
                    {
                        "name": "reportCard",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Report card details"
                    }
                }
            }
        },
        "/tenant/report-cards/{reportCard}/publish": {
            "post": {
                "tags": [
                    "Report Cards"
                ],
                "summary": "Publish Report Card",
                "description": "Mark a report card as published",
                "operationId": "ea0b4cfb60a8ad29bca3eff53cfaa22c",
                "parameters": [
                    {
                        "name": "reportCard",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect back"
                    }
                }
            }
        },
        "/tenant/report-cards/{reportCard}/pdf": {
            "get": {
                "tags": [
                    "Report Cards"
                ],
                "summary": "Download Report Card PDF",
                "description": "Download the PDF version of the report card",
                "operationId": "dfdc06972e7001ce156688f09ff14932",
                "parameters": [
                    {
                        "name": "reportCard",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "PDF File",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tenant/students/import": {
            "post": {
                "tags": [
                    "Students"
                ],
                "summary": "Import Students",
                "description": "Import students from Excel/CSV file",
                "operationId": "169dd6685c2de4252ea7f7a39d56c877",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "file": {
                                        "description": "Excel/CSV file",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect back with success/error"
                    }
                }
            }
        },
        "/tenant/students/template": {
            "get": {
                "tags": [
                    "Students"
                ],
                "summary": "Download Import Template",
                "description": "Download CSV template for student import",
                "operationId": "13bc5c07e3010e549b65fcf7eea5c799",
                "responses": {
                    "200": {
                        "description": "CSV Template",
                        "content": {
                            "text/csv": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tenant/students": {
            "get": {
                "tags": [
                    "Students"
                ],
                "summary": "List Students",
                "description": "Get list of students with filtering",
                "operationId": "40838abeace3f0f9df72fa2ea32f5700",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Search by name or NIS",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "class_id",
                        "in": "query",
                        "description": "Filter by class ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by status",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "active",
                                "graduated",
                                "transferred",
                                "dropout"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of students"
                    }
                }
            },
            "post": {
                "tags": [
                    "Students"
                ],
                "summary": "Create Student",
                "description": "Create a new student",
                "operationId": "797125c7968abfde3c4a2c9dc23765d8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nis",
                                    "name"
                                ],
                                "properties": {
                                    "nis": {
                                        "type": "string"
                                    },
                                    "nisn": {
                                        "type": "string"
                                    },
                                    "name": {
                                        "type": "string"
                                    },
                                    "gender": {
                                        "type": "string",
                                        "enum": [
                                            "male",
                                            "female"
                                        ]
                                    },
                                    "birth_place": {
                                        "type": "string"
                                    },
                                    "birth_date": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "religion": {
                                        "type": "string"
                                    },
                                    "address": {
                                        "type": "string"
                                    },
                                    "parent_name": {
                                        "type": "string"
                                    },
                                    "parent_phone": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "class_id": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect to index"
                    }
                }
            }
        },
        "/tenant/students/{student}": {
            "get": {
                "tags": [
                    "Students"
                ],
                "summary": "Show Student",
