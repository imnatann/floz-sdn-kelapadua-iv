# ==============================================
# FLOZ LMS - Environment Configuration
# ==============================================

# Application
APP_NAME=FLOZ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

# Central Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=floz_central
DB_USERNAME=floz_user
DB_PASSWORD=floz_secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache
CACHE_STORE=redis
CACHE_PREFIX=floz_

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis

# Mail (Mailpit for development)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@floz.id"
MAIL_FROM_NAME="${APP_NAME}"

# Storage (MinIO - S3 compatible)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minio_access_key
AWS_SECRET_ACCESS_KEY=minio_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=floz
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Tenancy
TENANCY_DATABASE_PREFIX=floz_tenant_
TENANCY_CENTRAL_DATABASE=floz_central

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Vite (Dev)
VITE_APP_NAME="${APP_NAME}"
